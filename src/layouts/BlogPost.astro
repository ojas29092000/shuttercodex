---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'articles'>['data'] & { body?: string };

const { title, description, pubDate, updatedDate, category, body } = Astro.props;

function readingTime(str: string) {
	return Math.max(1, Math.round(str.split(/\s+/).length / 200));
}
const minutes = readingTime(body ?? description);
const categoryLabels: Record<string, string> = {
	explainer: 'Explainer',
	smartphone: 'Smartphone',
	mirrorless: 'Mirrorless',
	comparison: 'Comparison',
};
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.article-wrap {
				max-width: 1080px;
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			/* ===== Dark title card ===== */
			.article-band {
				background: var(--ink);
				position: relative;
				overflow: hidden;
			}

			.article-band::before {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
				background-size: 44px 44px;
				-webkit-mask-image: radial-gradient(ellipse 75% 80% at center, black 30%, transparent 82%);
				mask-image: radial-gradient(ellipse 75% 80% at center, black 30%, transparent 82%);
				pointer-events: none;
			}

			.article-band::after {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(ellipse at center, transparent 55%, rgba(0, 0, 0, 0.35) 100%);
				pointer-events: none;
			}

			.article-header {
				max-width: 68ch;
				margin: 0 auto;
				padding: 3rem 1.5rem 2.5rem;
				position: relative;
				z-index: 2;
			}

			.crumb {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 0.65rem;
				letter-spacing: 0.14em;
				color: rgba(255, 255, 255, 0.45);
				text-decoration: none;
				margin-bottom: 1.75rem;
			}

			.crumb:hover {
				color: #7BA7FF;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 1.5rem;
				flex-wrap: wrap;
			}

			.article-category {
				font-family: var(--font-mono);
				font-size: 0.65rem;
				font-weight: 400;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--accent-warm);
				background: rgba(196, 135, 26, 0.14);
				padding: 3px 8px;
				border-radius: 3px;
			}

			.article-date {
				font-family: var(--font-body);
				font-size: 0.8125rem;
				color: rgba(255, 255, 255, 0.55);
			}

			.article-readtime {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				color: rgba(255, 255, 255, 0.5);
				letter-spacing: 0.04em;
			}

			.article-header h1 {
				font-family: var(--font-display);
				font-size: clamp(1.9rem, 4vw, 2.8rem);
				font-weight: 700;
				line-height: 1.1;
				letter-spacing: -0.02em;
				color: #ffffff;
				margin: 0 0 1rem;
			}

			.article-description {
				font-family: var(--font-body);
				font-size: 1.0625rem;
				line-height: 1.7;
				color: rgba(255, 255, 255, 0.68);
				margin: 0;
				border-left: 3px solid #5B8CFF;
				padding-left: 1rem;
			}

			/* Film edge: sprocket holes along the bottom of the band */
			.film-edge {
				display: flex;
				justify-content: center;
				gap: 18px;
				padding: 0 1.5rem 1.25rem;
				position: relative;
				z-index: 2;
				overflow: hidden;
			}

			.film-edge .perf {
				width: 10px;
				height: 14px;
				border: 1.5px solid rgba(255, 255, 255, 0.22);
				border-radius: 3px;
				flex: none;
			}

			/* Prose content */
			.prose {
				max-width: 68ch;
				margin: 0 auto;
				padding: 2.5rem 0 4rem;
			}

			.prose :global(p) {
				font-size: 1.0625rem;
				line-height: 1.8;
				color: var(--ink);
				margin: 0 0 1.5em;
			}

			/* Drop cap on first paragraph */
			.prose :global(> p:first-of-type::first-letter) {
				font-family: var(--font-display);
				font-size: 3.5em;
				font-weight: 700;
				line-height: 0.85;
				float: left;
				margin: 0.05em 0.1em 0 0;
				color: var(--accent);
			}

			.prose :global(h2) {
				font-family: var(--font-display);
				font-size: 1.5rem;
				font-weight: 700;
				color: var(--ink);
				margin: 2.5em 0 0.75em;
				padding-bottom: 0.4em;
				border-bottom: 2px solid var(--border);
				position: relative;
			}

			.prose :global(h2::before) {
				content: '';
				position: absolute;
				bottom: -2px;
				left: 0;
				width: 3rem;
				height: 2px;
				background: var(--accent);
			}

			.prose :global(h3) {
				font-family: var(--font-display);
				font-size: 1.2rem;
				font-weight: 700;
				color: var(--ink);
				margin: 2em 0 0.5em;
			}

			.prose :global(strong) {
				font-weight: 600;
				color: var(--ink);
			}

			.prose :global(a) {
				color: var(--accent);
				text-decoration: underline;
				text-underline-offset: 3px;
			}

			.prose :global(blockquote) {
				border-left: 3px solid var(--accent);
				margin: 2em 0;
				padding: 1rem 1.5rem;
				background: rgba(33, 81, 204, 0.04);
				border-radius: 0 4px 4px 0;
				font-style: italic;
				font-size: 1.0625rem;
				color: var(--ink);
			}

			.prose :global(blockquote p) {
				margin: 0;
				color: var(--ink);
			}

			.prose :global(pre) {
				font-family: var(--font-mono);
				font-size: 0.875em;
				background: var(--ink);
				color: var(--bg);
				padding: 1.5rem;
				border-radius: 6px;
				overflow-x: auto;
				margin: 1.5em 0;
				line-height: 1.6;
			}

			.prose :global(pre > code) {
				all: unset;
			}

			.prose :global(code) {
				font-family: var(--font-mono);
				font-size: 0.875em;
				background: var(--border);
				padding: 2px 6px;
				border-radius: 3px;
			}

			/* Diagram / figure styling */
			.prose :global(figure) {
				margin: 2.5em 0;
				text-align: center;
			}

			.prose :global(figcaption) {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--ink-muted);
				margin-top: 0.75rem;
			}

			.prose :global(svg) {
				max-width: 100%;
				height: auto;
			}

			.prose :global(img) {
				max-width: 100%;
				height: auto;
				border-radius: 6px;
				margin: 1em 0;
			}

			.prose :global(hr) {
				border: none;
				border-top: 1px solid var(--border);
				margin: 2.5em 0;
			}

			.prose :global(ul),
			.prose :global(ol) {
				padding-left: 1.5em;
				margin: 0 0 1.5em;
			}

			.prose :global(li) {
				font-size: 1.0625rem;
				line-height: 1.75;
				color: var(--ink);
				margin-bottom: 0.4em;
			}

			.prose :global(table) {
				width: 100%;
				border-collapse: collapse;
				font-size: 0.9rem;
				margin: 1.5em 0;
			}

			.prose :global(th) {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--ink-muted);
				border-bottom: 2px solid var(--border);
				padding: 0.5rem 0.75rem;
				text-align: left;
			}

			.prose :global(td) {
				padding: 0.6rem 0.75rem;
				border-bottom: 1px solid var(--border);
				color: var(--ink);
				font-size: 0.9375rem;
			}

			/* Reading progress bar */
			.progress-track {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				height: 3px;
				z-index: 200;
				pointer-events: none;
			}

			.progress-bar {
				height: 100%;
				background: var(--accent);
				transform: scaleX(0);
				transform-origin: left center;
			}

			/* TL;DR takeaways box */
			.prose :global(.takeaways) {
				background: var(--surface);
				border: 1px solid var(--border);
				border-left: 3px solid var(--accent);
				border-radius: 0 6px 6px 0;
				padding: 1.25rem 1.5rem;
				margin: 0 0 2.5em;
			}

			.prose :global(.takeaways-label) {
				font-family: var(--font-mono);
				font-size: 0.65rem;
				text-transform: uppercase;
				letter-spacing: 0.18em;
				color: var(--accent-warm-ink);
				display: block;
				margin-bottom: 0.75rem;
			}

			.prose :global(.takeaways ul) {
				margin: 0;
				padding-left: 1.1em;
			}

			.prose :global(.takeaways li) {
				font-size: 0.9375rem;
				line-height: 1.65;
				margin-bottom: 0.5em;
				color: var(--ink);
			}

			.prose :global(.takeaways li:last-child) {
				margin-bottom: 0;
			}

			/* Side-by-side product photos. Kept as two separate <img> elements
			   rather than one composited file: under CC BY-SA a composite would
			   be a derivative work, whereas a collection of two credited images
			   is not. Each keeps its own attribution. */
			.prose :global(.photo-pair) {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0.75rem;
			}

			.prose :global(.photo-pair img) {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 8px;
				background: var(--border);
			}

			.prose :global(.photo-pair figcaption) {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				text-align: center;
				margin-top: 0.5rem;
				color: var(--ink-muted);
			}

			@media (max-width: 460px) {
				.prose :global(.photo-pair) {
					gap: 0.5rem;
				}
				.prose :global(.photo-pair figcaption) {
					font-size: 0.6rem;
					letter-spacing: 0.06em;
				}
			}

			/* Highlighter for the one line per section a skimmer must retain.
			   Full-coverage band. box-decoration-break: clone is required so the
			   padding and radius repeat on every line when a highlight wraps —
			   without it a wrapped highlight loses its ends and looks broken. */
			.prose :global(mark) {
				background: rgba(196, 135, 26, 0.26);
				color: inherit;
				padding: 0.12em 0.24em;
				margin: 0 -0.06em;
				border-radius: 3px;
				-webkit-box-decoration-break: clone;
				box-decoration-break: clone;
			}

			/* "The engineering" — first-principles explanation behind a verdict.
			   Amber marks hardware/physics reasoning, per the design tokens. */
			.prose :global(.engineering) {
				background: rgba(196, 135, 26, 0.055);
				border: 1px solid rgba(196, 135, 26, 0.2);
				border-left: 3px solid var(--accent-warm);
				border-radius: 0 6px 6px 0;
				padding: 1rem 1.25rem;
				margin: 0 0 1.75em;
			}

			.prose :global(.engineering p) {
				margin: 0;
				font-size: 0.9375rem;
				line-height: 1.68;
				color: var(--ink);
			}

			.prose :global(.engineering strong:first-child) {
				font-family: var(--font-mono);
				font-size: 0.65rem;
				text-transform: uppercase;
				letter-spacing: 0.16em;
				color: var(--accent-warm-ink);
				font-weight: 600;
			}

			/* "See it yourself" — pointers to source imagery hosted elsewhere.
			   We never reproduce third-party photos; we send the reader to them. */
			.prose :global(.see-also) {
				background: var(--surface);
				border: 1px dashed var(--border);
				border-radius: 6px;
				padding: 0.9rem 1.15rem;
				margin: 0 0 2em;
			}

			.prose :global(.see-also p) {
				margin: 0;
				font-size: 0.875rem;
				line-height: 1.6;
				color: var(--ink-muted);
			}

			.prose :global(.see-also strong) {
				font-family: var(--font-mono);
				font-size: 0.68rem;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--accent-warm-ink);
				font-weight: 600;
			}

			/* External links get an unobtrusive outbound marker */
			.prose :global(a[target='_blank'])::after {
				content: '↗';
				display: inline-block;
				margin-left: 0.18em;
				font-size: 0.78em;
				vertical-align: baseline;
				opacity: 0.55;
			}

			.updated-note {
				font-family: var(--font-mono);
				font-size: 0.72rem;
				color: rgba(255, 255, 255, 0.5);
				letter-spacing: 0.04em;
				margin-top: 0.5rem;
			}

			/* End-of-roll marker */
			.article-end {
				text-align: center;
				padding: 0 0 4rem;
			}

			.end-roll {
				font-family: var(--font-mono);
				font-size: 0.68rem;
				letter-spacing: 0.28em;
				color: var(--ink-muted);
				opacity: 0.6;
				margin: 0 0 1rem;
			}

			.back-link {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				letter-spacing: 0.08em;
				color: var(--accent);
				text-decoration: none;
			}

			.back-link:hover {
				color: var(--ink);
			}

			@media (max-width: 720px) {
				.article-header {
					padding: 2rem 1.25rem 1.5rem;
				}
				.article-header h1 {
					font-size: 1.75rem;
				}
				.prose :global(> p:first-of-type::first-letter) {
					font-size: 2.8em;
				}
			}
		</style>
	</head>

	<body>
		<div class="progress-track" aria-hidden="true"><div class="progress-bar"></div></div>
		<Header />
		<main style="width: 100%; max-width: 100%; padding: 0;">
			<article>
				<div class="article-band">
					<header class="article-header">
						<a class="crumb" href="/articles">&#8592; CONTACT SHEET</a>
						<div class="article-meta">
							{category && <span class="article-category">{categoryLabels[category] ?? category}</span>}
							<span class="article-date"><FormattedDate date={pubDate} /></span>
							<span class="article-readtime">{minutes} min read</span>
						</div>
						<h1>{title}</h1>
						<p class="article-description">{description}</p>
						{updatedDate && (
							<p class="updated-note">Updated <FormattedDate date={updatedDate} /></p>
						)}
					</header>
					<div class="film-edge" aria-hidden="true">
						{Array.from({ length: 14 }).map(() => <span class="perf"></span>)}
					</div>
				</div>
				<div class="article-wrap">
					<div class="prose">
						<slot />
					</div>
					<footer class="article-end">
						<p class="end-roll" aria-hidden="true">&#8212; END OF ROLL &#8212;</p>
						<a class="back-link" href="/articles">Back to the contact sheet &#8594;</a>
					</footer>
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			gsap.registerPlugin(ScrollTrigger);

			// Progress bar mirrors the user's own scrolling — allowed under reduced motion
			gsap.to('.progress-bar', {
				scaleX: 1,
				ease: 'none',
				scrollTrigger: {
					trigger: '.prose',
					start: 'top top',
					end: 'bottom bottom',
					scrub: true
				}
			});

			// GSAP sets inline styles, so the CSS prefers-reduced-motion rule can't stop it — guard in JS
			const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (!reduceMotion) {
				gsap.from('.article-header', {
					opacity: 0,
					y: 16,
					duration: 0.65,
					ease: 'power2.out',
					delay: 0.1
				});

				document.querySelectorAll('.prose h2').forEach((el) => {
					gsap.from(el, {
						opacity: 0,
						x: -14,
						duration: 0.45,
						ease: 'power2.out',
						scrollTrigger: {
							trigger: el,
							start: 'top 86%',
							once: true
						}
					});
				});

				document.querySelectorAll('.prose figure').forEach((el) => {
					gsap.from(el, {
						opacity: 0,
						y: 18,
						duration: 0.5,
						ease: 'power2.out',
						scrollTrigger: {
							trigger: el,
							start: 'top 86%',
							once: true
						}
					});
				});
			}
		</script>
	</body>
</html>
