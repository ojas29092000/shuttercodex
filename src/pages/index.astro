---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 4em 1em 3em;
				max-width: 680px;
				margin: 0 auto;
			}
			.hero h1 {
				font-size: 2.5em;
				line-height: 1.2;
				margin-bottom: 0.5em;
			}
			.tagline {
				font-size: 1.15em;
				color: rgb(var(--gray-dark));
				margin-bottom: 1.5em;
				line-height: 1.6;
			}
			.cta {
				display: inline-block;
				padding: 0.6em 1.4em;
				background: var(--accent);
				color: white;
				border-radius: 4px;
				text-decoration: none;
				font-weight: 600;
			}
			.cta:hover {
				opacity: 0.9;
			}
			.pillars {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.5rem;
				max-width: 960px;
				margin: 3em auto;
				padding: 0 1em;
			}
			.pillar {
				padding: 1.5em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
			}
			.pillar h3 {
				margin: 0 0 0.5em;
				font-size: 1.05em;
			}
			.pillar p {
				margin: 0 0 1em;
				font-size: 0.9em;
				color: rgb(var(--gray-dark));
				line-height: 1.5;
			}
			.pillar a {
				font-size: 0.9em;
				font-weight: 600;
				color: var(--accent);
				text-decoration: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>The technical reference for camera buyers</h1>
				<p class="tagline">
					Written by a software engineer specializing in embedded camera systems and AI vision technology.
					We explain <em>why</em> cameras perform the way they do — not just what the specs say.
				</p>
				<a href="/articles" class="cta">Browse Articles →</a>
			</section>
			<section class="pillars">
				<div class="pillar">
					<h3>Camera Technology</h3>
					<p>ISP pipelines, sensor physics, autofocus systems — the engineering behind the image.</p>
					<a href="/articles">Read →</a>
				</div>
				<div class="pillar">
					<h3>Smartphone Cameras</h3>
					<p>Computational photography decoded. What makes a great camera phone and why.</p>
					<a href="/articles">Read →</a>
				</div>
				<div class="pillar">
					<h3>Mirrorless Buying Guides</h3>
					<p>Technical buying intelligence for mirrorless cameras. Cut through the marketing.</p>
					<a href="/articles">Read →</a>
				</div>
				<div class="pillar">
					<h3>Camera Comparisons</h3>
					<p>Head-to-head analysis grounded in sensor technology and image processing.</p>
					<a href="/articles">Read →</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
