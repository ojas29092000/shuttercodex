---
import ApertureMark from './ApertureMark.astro';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="wordmark"><ApertureMark size={19} /> ShutterCodex</a>
		<div class="nav-links">
			<HeaderLink href="/articles">Articles</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		background: var(--surface);
		border-bottom: 1px solid var(--border);
		z-index: 100;
	}

	nav {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 56px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.wordmark {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.2rem;
		color: var(--accent);
		text-decoration: none;
		letter-spacing: -0.01em;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}

	.wordmark:hover {
		color: var(--ink);
	}

	/* Aperture rotates like an iris ring when the wordmark is hovered */
	.wordmark:hover :global(.aperture-mark) {
		transform: rotate(60deg);
	}

	.nav-links {
		display: flex;
		gap: 2rem;
		align-items: center;
	}

	.nav-links :global(a) {
		font-family: var(--font-body);
		font-size: 0.8125rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-muted);
		text-decoration: none;
		padding-bottom: 2px;
		border-bottom: 2px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}

	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--ink);
		border-bottom-color: var(--accent);
	}
</style>
